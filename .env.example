DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://erp:erp@localhost:5432/erp_inoovated

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@inoovated.com.br

# Uploads locais. No Railway, monte um Volume em /app/media e use MEDIA_ROOT=/app/media.
# Sem volume, a imagem pode ate salvar, mas some em novo deploy/restart.
MEDIA_URL=/media/
MEDIA_ROOT=media

# ViaCEP
VIACEP_URL=https://viacep.com.br/ws/{cep}/json/

# Focus NFe (https://app.focusnfe.com.br) — emissao de documentos fiscais
# FOCUSNFE_AMBIENTE: 1=producao, 2=homologacao
FOCUSNFE_TOKEN=
FOCUSNFE_AMBIENTE=2
# Token livre que protege o endpoint /fiscal/webhook/focusnfe/ (opcional)
FOCUSNFE_WEBHOOK_TOKEN=
