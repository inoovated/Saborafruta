DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://erp:erp@localhost:5432/erp_inoovated

# Futuro Supabase/Postgres externo.
# Nao usar dados reais no plano free e nao commitar URLs reais com senha.
# DATABASE_URL=postgres://postgres.PROJECT_REF:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# DATABASE_SSL_REQUIRE=True
# DATABASE_CONN_MAX_AGE=0

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@inoovated.com.br

# Uploads locais. No Railway, monte um Volume em /app/media e use MEDIA_ROOT=/app/media.
# Sem volume, a imagem pode ate salvar, mas some em novo deploy/restart.
MEDIA_URL=/media/
MEDIA_ROOT=media

# ViaCEP
VIACEP_URL=https://viacep.com.br/ws/{cep}/json/

# Futuro Cloudflare/R2.
# Manter desativado no MVP de custo zero. Quando migrar arquivos, configurar
# storage externo com variaveis proprias e testar restauracao antes de producao.
